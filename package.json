      "pdfjs-dist": "^5.5.207",
      "pptxgenjs": "^4.0.1",
      "puppeteer": "^24.35.0",
      "puppeteer-extra": "^3.3.6",
      "puppeteer-extra-plugin-stealth": "^2.11.2",
      "sharp": "^0.33.5",
      "speaker": "^0.5.5",
      "telegraf": "^4.16.3",
      "uuid": "^11.1.0",
      "wav": "^1.0.2",
      "ws": "^8.18.0",
      "yaml": "^2.3.4"
   },
   "engines": {
      "node": ">=18.0.0"
   }
}
